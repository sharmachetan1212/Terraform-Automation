aws_region   = "us-east-1"
project_name = "infra-automaton"

# Enable only what the user asks for. Disabled services create no resources.
enable_vpc                      = true
enable_ec2                      = true
enable_s3                       = true
enable_dynamodb                 = true
enable_lambda                   = true
enable_cloudwatch_log_group     = false
enable_sqs                      = false
enable_sns                      = false
enable_sns_to_sqs_subscription  = false
enable_rds                      = false

# Existing network values are used only when enable_vpc = false.
existing_vpc_id     = null
existing_subnet_ids = []

# VPC values.
vpc_cidr_block          = "10.10.0.0/16"
subnet_count            = 2
map_public_ip_on_launch = true

# EC2 values.
ami_id                  = "ami-xxxxxxxxxxxxxxxxx"
instance_type           = "t3.micro"
key_name                = null
allowed_ssh_cidr_blocks = ["0.0.0.0/0"]

# S3 values. Bucket names must be globally unique.
s3_bucket_name = "your-globally-unique-free-tier-bucket-name"

# Lambda and CloudWatch values.
cloudwatch_log_retention_days = 7
lambda_runtime                = "python3.12"
lambda_memory_size            = 128
lambda_timeout                = 10

# SQS and SNS values.
sqs_message_retention_seconds = 345600

# RDS values. Enable only when the user confirms AWS Free Tier eligibility.
rds_instance_class    = "db.t3.micro"
rds_allocated_storage = 20
rds_engine_version    = "8.0"
rds_db_name           = "appdb"
rds_username          = "admin"
rds_password          = null
